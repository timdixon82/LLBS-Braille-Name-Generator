# Operating system files
.DS_Store
Thumbs.db

# iCloud Drive sync conflict files. When the same file is modified in two
# places (or iCloud perceives a conflict), it creates a sibling with a
# numeric suffix before the extension: `name 2.md`, `name 3.md`, and so on.
# They are sync artefacts, never intentional, and never belong in the repository.
* 2.*
* 3.*
* 4.*
* 5.*

# Editor files
.vscode/
.idea/

# Secrets and environment files
.env
.env.*
!.env.example
*.pem
*.key

# Dependencies
node_modules/
vendor/

# Build output
dist/
build/

# Logs
*.log
npm-debug.log*
.npm

# Claude Code local settings — local to this machine, not shared
.claude/settings.local.json

# CI-only Pa11y config, derived from pa11y.json in the accessibility workflow. Generated, never committed.
pa11y.ci.json
