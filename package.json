{
  "name": "llbs-braille-name-generator",
  "version": "1.0.0",
  "description": "A braille name generator for Lincoln and Lindsey Blind Society.",
  "private": true,
  "type": "module",
  "scripts": {
    "lint:html": "html-validate index.html",
    "lint:css": "stylelint \"css/**/*.css\" --allow-empty-input",
    "lint:js": "eslint \"js/**/*.js\" --no-error-on-unmatched-pattern",
    "lint": "npm run lint:html && npm run lint:css && npm run lint:js"
  },
  "devDependencies": {
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "html-validate": "^11.2.0",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0"
  }
}
